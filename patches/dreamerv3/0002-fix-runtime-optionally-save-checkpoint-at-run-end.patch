From 5168475b7a4413f9575933b4580e7073caea2114 Mon Sep 17 00:00:00 2001
From: sixun-liu <sixun-liu@users.noreply.github.com>
Date: Tue, 21 Jul 2026 13:57:30 +0800
Subject: [PATCH 2/2] fix(runtime): optionally save checkpoint at run end

---
 dreamerv3/configs.yaml       | 1 +
 embodied/run/train.py        | 2 ++
 embodied/tests/test_train.py | 1 +
 3 files changed, 4 insertions(+)

diff --git a/dreamerv3/configs.yaml b/dreamerv3/configs.yaml
index 786b67e..65e30d1 100644
--- a/dreamerv3/configs.yaml
+++ b/dreamerv3/configs.yaml
@@ -52,6 +52,7 @@ defaults:
     log_every: 120
     report_every: 300
     save_every: 900
+    save_at_end: False
     envs: 16
     eval_envs: 4
     eval_eps: 1
diff --git a/embodied/run/train.py b/embodied/run/train.py
index fc791ec..23ffe8f 100644
--- a/embodied/run/train.py
+++ b/embodied/run/train.py
@@ -116,4 +116,6 @@ def train(make_agent, make_replay, make_env, make_stream, make_logger, args):
     if should_save(step):
       cp.save()
 
+  if args.save_at_end:
+    cp.save()
   logger.close()
diff --git a/embodied/tests/test_train.py b/embodied/tests/test_train.py
index 6f76fc1..60a0124 100644
--- a/embodied/tests/test_train.py
+++ b/embodied/tests/test_train.py
@@ -58,6 +58,7 @@ class TestTrain:
         log_every=0.1,
         report_every=0.2,
         save_every=0.2,
+        save_at_end=True,
         report_batches=1,
         from_checkpoint='',
         usage=dict(psutil=True),
-- 
